# Variáveis de Configuração Supabase
# Copie este arquivo para .env.local e preencha com suas credenciais

# Chave pública do Supabase (pode ser exposta no frontend)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública anonônia do Supabase (pode ser exposta no frontend)
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# ====== CONFIGURAÇÃO DE SEO ======
# Credenciais do Google Search Console (para Edge Function)
# IMPORTANTE: Configure isso no Dashboard do Supabase em Settings > Secrets
# NÃO cole aqui, use apenas no Supabase Secrets com o nome: GOOGLE_SERVICE_ACCOUNT
# Este é um arquivo JSON Service Account do Google Cloud
GOOGLE_SERVICE_ACCOUNT_FILE=../seo-api-XXXXX.json

# Nota: A chave de API publicável (que você compartilhou) deve ser:
# 1. Regenerada no dashboard do Supabase
# 2. Colocada APENAS como Secret no Supabase (não em arquivo)
# 3. Usada pela Edge Function para autenticar com Google

